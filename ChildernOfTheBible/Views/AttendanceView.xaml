<UserControl x:Class="ChildernOfTheBible.Views.AttendanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="210"/>
        </Grid.ColumnDefinitions>

        <!-- Left: scan area -->
        <Grid Grid.Column="0" Margin="24,20,16,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold"
                           Foreground="#2C2C2A"/>
                <TextBlock Text="Scan a member barcode to register attendance"
                           FontSize="12" Foreground="#888780" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- Meeting buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Start meeting"
                        Command="{Binding StartMeetingCommand}"
                        IsEnabled="{Binding MeetingActive, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource SuccessButtonStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="End meeting"
                        Command="{Binding EndMeetingCommand}"
                        IsEnabled="{Binding MeetingActive}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </StackPanel>

            <!-- Scan box -->
            <Border Grid.Row="2" Margin="0,0,0,12" CornerRadius="10" Padding="20,16"
                    BorderThickness="1.5" BorderBrush="#B5D4F4" Background="#F4F8FD">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="8" Background="#E6F1FB"
                            HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="▦" Foreground="#185FA5" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Scan barcode or type and press Enter"
                               FontSize="13" Foreground="#185FA5"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBox x:Name="BarcodeBox"
                             Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Padding="12,10"
                             KeyDown="BarcodeBox_KeyDown"
                             IsEnabled="{Binding MeetingActive}"
                             Width="340" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Status -->
            <Border Grid.Row="3" CornerRadius="8" Padding="14,10" Margin="0,0,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#E1F5EE"/>
                        <Setter Property="BorderBrush" Value="#9FE1CB"/>
                        <Setter Property="BorderThickness" Value="0.5"/>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{Binding StatusColor}"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>

        <!-- Right: stats + recent -->
        <Grid Grid.Column="1" Margin="0,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Stat card -->
            <Border Grid.Row="0" CornerRadius="8" Background="#F1EFE8"
                    Padding="14,12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Checked in today" FontSize="11"
                               Foreground="#888780" Margin="0,0,0,4"/>
                    <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#2C2C2A">
                        <Run Text="{Binding RecentCheckins.Count, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Recent check-ins -->
            <Border Grid.Row="1" CornerRadius="10" Background="White"
                    BorderBrush="#E8E7E0" BorderThickness="0.5" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Recent check-ins"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#2C2C2A" Margin="0,0,0,10"/>
                    <ListBox ItemsSource="{Binding RecentCheckins}"
                             BorderThickness="0" Background="Transparent"
                             FontSize="12" Foreground="#2C2C2A">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0,6"/>
                                <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
                                <Setter Property="BorderBrush" Value="#EEEDE6"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>