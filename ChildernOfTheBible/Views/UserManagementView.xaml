<UserControl x:Class="ChildernOfTheBible.Views.UserManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: member list -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBox DockPanel.Dock="Top" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
               Margin="0,0,0,6" Padding="4" Tag="Search members..."/>
            <Button DockPanel.Dock="Top" Content="Refresh" Command="{Binding LoadMembersCommand}" Margin="0,0,0,6"/>
            <DataGrid ItemsSource="{Binding Members}" SelectedItem="{Binding SelectedMember}"
                AutoGenerateColumns="False" IsReadOnly="True"
                SelectionChanged="DataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="First" Binding="{Binding FirstName}" Width="*"/>
                    <DataGridTextColumn Header="Last"  Binding="{Binding LastName}"  Width="*"/>
                    <DataGridTextColumn Header="Barcode" Binding="{Binding BarcodeId}" Width="1.2*"/>
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- RIGHT: form + barcode -->
        <StackPanel Grid.Column="1" Margin="10,0,0,0">
            <TextBlock Text="Member Details" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBox Text="{Binding FirstName}" Margin="0,0,0,4" Padding="4"
               Tag="First Name"/>
            <TextBox Text="{Binding LastName}"  Margin="0,0,0,4" Padding="4"
               Tag="Last Name"/>
            <TextBox Text="{Binding Email}"     Margin="0,0,0,4" Padding="4"
               Tag="Email (stored encrypted)"/>
            <TextBox Text="{Binding Phone}"     Margin="0,0,0,12" Padding="4"
               Tag="Phone (stored encrypted)"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Add New" Command="{Binding AddMemberCommand}" Margin="0,0,8,0" Padding="12,6"/>
                <Button Content="Save Edit" Command="{Binding SaveEditCommand}"  Margin="0,0,8,0" Padding="12,6"/>
                <Button Content="Deactivate" Command="{Binding DeactivateCommand}" Padding="12,6" Background="#FFDDDD"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#2563EB" TextWrapping="Wrap" Margin="0,0,0,12"/>
            <TextBlock Text="Member Barcode" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Image x:Name="BarcodeImg"
                   Source="{Binding BarcodeImage}" Height="80" HorizontalAlignment="Left"
                   Stretch="Uniform" Margin="0,0,0,8"/>
            <Button Content="Print Barcode" Click="PrintBarcode_Click" Padding="12,6"/>
        </StackPanel>
    </Grid>
</UserControl>
