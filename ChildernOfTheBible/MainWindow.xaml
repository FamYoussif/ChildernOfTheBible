<Window x:Class="ChildernOfTheBible.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:ChildernOfTheBible"
        mc:Ignorable="d"
        Title="Bible Study Attendance System"
        Height="680" Width="1100" MinHeight="580" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F1EFE8">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="215"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="#1E3A5F">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Brand -->
            <Border Grid.Row="0" BorderBrush="#1A3355"
                    BorderThickness="0,0,0,0.5" Padding="16,18,16,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="32" Height="32" CornerRadius="8"
                            Background="#185FA5" Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="✝" Foreground="White" FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ChildernOfTheBible"
                                   Foreground="White"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="Attendance System"
                                   Foreground="#4A6FA8"
                                   FontSize="10" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Navigation -->
            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                <TextBlock Text="MODULES"
                           Foreground="#3A5A80" FontSize="9"
                           Margin="16,8,0,6" FontWeight="SemiBold"/>

                <Button Command="{Binding NavigateToAttendanceCommand}"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="▣" Foreground="#7B8DB8" FontSize="12"
                                   Margin="0,0,9,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Attendance" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavigateToMembersCommand}"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◉" Foreground="#7B8DB8" FontSize="12"
                                   Margin="0,0,9,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Members" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavigateToReportsCommand}"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="≡" Foreground="#7B8DB8" FontSize="14"
                                   Margin="0,0,9,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Reports" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- DB status -->
            <Border Grid.Row="2" Margin="12,0,12,10" CornerRadius="7"
                    Padding="10,7" Background="#0D2E4A"
                    BorderBrush="#1D5F4A" BorderThickness="0.5">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Fill="#5DCAA5"
                             Margin="0,0,7,0" VerticalAlignment="Center"/>
                    <TextBlock Text="DB: Connected" Foreground="#9FE1CB"
                               FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="3" BorderBrush="#1A3355"
                    BorderThickness="0,0.5,0,0" Padding="14,12">
                <StackPanel Orientation="Horizontal">
                    <Border Width="28" Height="28" CornerRadius="14"
                            Background="#185FA5" Margin="0,0,9,0">
                        <TextBlock Text="AD" Foreground="White"
                                   FontSize="10" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Admin" Foreground="#C8D4E8" FontSize="12"/>
                        <TextBlock Text="Administrator" Foreground="#4A6FA8" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="#E8E7E0" BorderThickness="0,0,0,0.5">
                <Grid Margin="22,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock Text="Church Attendance System"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#2C2C2A"/>
                        <TextBlock FontSize="11" Foreground="#888780" Margin="0,1,0,0"
                                   Text="{Binding Source={x:Static sys:DateTime.Now},
                                          StringFormat='{}{0:dddd, MMMM dd, yyyy}'}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Padding="20" Background="#F7F6F2">
                <Border Background="White" CornerRadius="10"
                        BorderBrush="#E8E7E0" BorderThickness="0.5">
                    <ContentControl Content="{Binding CurrentViewModel}"/>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>