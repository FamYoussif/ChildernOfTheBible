<UserControl x:Class="ChildernOfTheBible.Views.UserManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="230"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: member list -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="{Binding Title}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="#2C2C2A"/>
                <TextBlock Text="Click a row to edit · search by name or barcode"
                           FontSize="12" Foreground="#888780" Margin="0,3,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Margin="0,0,8,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10,8"/>
                <Button Grid.Column="1" Content="Refresh"
                        Command="{Binding LoadMembersCommand}"
                        Style="{StaticResource GhostButtonStyle}"/>
            </Grid>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Members}"
                      SelectedItem="{Binding SelectedMember}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionChanged="DataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="First name"
                                        Binding="{Binding FirstName}" Width="*"/>
                    <DataGridTextColumn Header="Last name"
                                        Binding="{Binding LastName}"  Width="*"/>
                    <DataGridTextColumn Header="Barcode ID"
                                        Binding="{Binding BarcodeId}" Width="1.3*"/>
                    <DataGridCheckBoxColumn Header="Active"
                                            Binding="{Binding IsActive}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- RIGHT: form panel — no ScrollViewer, fixed compact layout -->
        <Border Grid.Column="1" CornerRadius="10" Background="White"
                BorderBrush="#E8E7E0" BorderThickness="0.5" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0"
                           Text="Member details"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#2C2C2A" Margin="0,0,0,12"/>

                <!-- First + Last name on one row -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="First name" FontSize="11"
                                   Foreground="#888780" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding FirstName,
                                        UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Last name" FontSize="11"
                                   Foreground="#888780" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding LastName,
                                        UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- Email -->
                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                    <TextBlock Text="Email (optional)" FontSize="11"
                               Foreground="#888780" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Email,
                                    UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Phone -->
                <StackPanel Grid.Row="3" Margin="0,0,0,14">
                    <TextBlock Text="Phone — e.g. 01012345678" FontSize="11"
                               Foreground="#888780" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Phone,
                                    UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Add / Save edit -->
                <Grid Grid.Row="4" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Add new"
                            Command="{Binding AddMemberCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Grid.Column="2" Content="Save edit"
                            Command="{Binding SaveEditCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            IsEnabled="{Binding IsEditing}"/>
                </Grid>

                <!-- Deactivate / Reactivate -->
                <Grid Grid.Row="5" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Deactivate"
                            Command="{Binding DeactivateCommand}"
                            Style="{StaticResource DangerButtonStyle}"/>
                    <Button Grid.Column="2" Content="Reactivate"
                            Command="{Binding ReactivateCommand}"
                            Style="{StaticResource SuccessButtonStyle}"/>
                </Grid>

                <!-- Clear -->
                <Button Grid.Row="6" Content="Clear form"
                        Command="{Binding ClearSelectionCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"/>

                <!-- Status -->
                <TextBlock Grid.Row="7"
                           Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusColor}"
                           FontSize="11" TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <!-- Divider -->
                <Border Grid.Row="8" Height="0.5"
                        Background="#E8E7E0" Margin="0,0,0,12"/>

                <!-- Barcode label -->
                <TextBlock Grid.Row="9"
                           Text="Member barcode"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#2C2C2A" Margin="0,0,0,6"/>

                <!-- Barcode image -->
                <Border Grid.Row="10" CornerRadius="7" Background="#F7F6F2"
                        BorderBrush="#E8E7E0" BorderThickness="0.5"
                        Height="56" Margin="0,0,0,6">
                    <Image x:Name="BarcodeImg"
                           Source="{Binding BarcodeImage}"
                           Stretch="Uniform" Margin="6"/>
                </Border>

                <!-- Print -->
                <Button Grid.Row="11" Content="Print barcode"
                        Click="PrintBarcode_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>