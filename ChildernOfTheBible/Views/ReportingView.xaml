<UserControl x:Class="ChildernOfTheBible.Views.ReportingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Report controls -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="By Meeting:" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                <ComboBox ItemsSource="{Binding Meetings}" SelectedItem="{Binding SelectedMeeting}"
                  DisplayMemberPath="MeetingDate" Width="180" Margin="0,0,8,0"/>
                <Button Content="Run" Command="{Binding RunMeetingReportCommand}" Padding="12,4"/>
            </StackPanel>
            <TextBlock Text="By Date Range:" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <DatePicker SelectedDate="{Binding RangeFrom}" Margin="0,0,8,0"/>
                <TextBlock Text="to" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding RangeTo}"   Margin="0,0,8,0"/>
                <Button Content="Run" Command="{Binding RunRangeReportCommand}" Padding="12,4"/>
            </StackPanel>
        </StackPanel>

        <!-- Export + status -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Export CSV" Command="{Binding ExportCsvCommand}" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="Export PDF" Command="{Binding ExportPdfCommand}" Padding="12,6" Margin="0,0,16,0"/>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="#2563EB"/>
        </StackPanel>

        <!-- Results grid -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding ReportRows}"
              AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"       Binding="{Binding FullName}"    Width="2*"/>
                <DataGridTextColumn Header="Barcode"    Binding="{Binding BarcodeId}"   Width="1.5*"/>
                <DataGridTextColumn Header="Date"       Binding="{Binding MeetingDate, StringFormat=dd/MM/yyyy}" Width="*"/>
                <DataGridTextColumn Header="Check-in"   Binding="{Binding CheckInTime, StringFormat=HH:mm}"     Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
